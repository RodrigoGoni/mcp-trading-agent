# =============================================================================
# Finance Agent — Variables de entorno
# Copiar a .env y completar los valores
# =============================================================================

# ── LLM (vLLM corriendo localmente) ──────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1
MODEL_NAME=Qwen/Qwen2.5-32B-Instruct-AWQ

# ── Qdrant (vector store para memorizar decisiones) ──────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=finance_decisions

# ── Simulación: parámetros por defecto ───────────────────────────────────────
INITIAL_CAPITAL=10000.0
YEARS=3
# Granularidad: "1d" (diaria), "1wk" (semanal), "1mo" (mensual)
BACKTEST_INTERVAL=1wk
# Lista de tickers separada por comas
TICKERS=AAPL,TSLA,MSFT,GOOGL,NVDA,SPY,QQQ,XLE,XOM,CVX,AMZN,META,AMD,AVGO,TSM,INTC,QCOM,NFLX,ADBE,CRM,ORCL,UBER,PYPL,SPOT

# ── Embedding model (sentence-transformers, ya instalado en el venv) ──────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Parámetros de gestión de riesgo del agente ───────────────────────────────
# Porcentaje máximo del portfolio que puede exponerse a un solo activo (0-1)
MAX_POSITION_PCT=0.25
# Porcentaje mínimo de cash que debe mantener el portfolio (0-1)
MIN_CASH_PCT=0.05
